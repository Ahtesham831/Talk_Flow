{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://talk-flow-gules.vercel.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://talk-flow-gules.vercel.app/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}